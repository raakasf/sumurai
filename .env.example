# Core Secrets (REQUIRED)
# Generate JWT secret with: openssl rand -hex 32
JWT_SECRET=replace-with-32-hex-chars-from-openssl

# Generate encryption key with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars-from-openssl

# Database password (change this for production)
POSTGRES_PASSWORD=password

# Seq logging service password
SEQ_PASSWORD=ChangeMe123!

# Seq API key for OpenTelemetry (generate a unique value)
SEQ_API_KEY=your-seq-api-key

# Default financial provider for new sessions / UI: plaid | teller
DEFAULT_PROVIDER=teller

# Plaid (set when testing Plaid; values from Plaid Dashboard → Keys → Sandbox)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# Teller Integration (REQUIRED)
# Get these from your Teller account at https://teller.io
TELLER_APPLICATION_ID=your-teller-app-id
TELLER_CERT_PATH=./.certs/teller/certificate.pem
TELLER_KEY_PATH=./.certs/teller/private_key.pem


